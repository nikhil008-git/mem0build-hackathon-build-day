DATABASE_URL=postgresql://user:password@localhost:5432/riftnew
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Rift services
API_PORT=8080
INGEST_PORT=8081
REMEDIATION_PORT=8082
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_PROJECT_SLUG=demo

# SDK / Hermes plugin
RIFT_API_KEY=rift_test_demo_key
RIFT_PROJECT_ID=demo
RIFT_ENDPOINT=http://localhost:8081

# Remediation — Hermes + GitHub PR
HERMES_REMEDIATION_URL=http://localhost:8083/analyze
HERMES_REMEDIATION_PORT=8083
HERMES_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_API_KEY=...  # or ANTHROPIC_API_KEY / OPENAI_API_KEY (Hermes uses your existing config)
# GitHub auto-PR — replace with your repo + token when ready
GITHUB_REPO=gittt/rift-support-agent-demo
GITHUB_TOKEN=
GITHUB_BASE_BRANCH=main
